# Copy to .env and fill in your own Nyas project credentials.
# Get these by running:  nyas project <your-project-id> --json

# Session pooling URI (IPv4-compatible; recommended for local dev / ORMs)
DATABASE_URL=postgresql://USER.PROJECTID:PASSWORD@db-pool1.nyas.io:5432/DBNAME

# Direct connection (IPv6-only) — optional fallback
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@db.PROJECTID.nyas.io:5432/DBNAME

NYAS_PROJECT_ID=your-project-id
