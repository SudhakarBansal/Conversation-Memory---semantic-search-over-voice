# Copy this file to .env and fill in Nyas project credentials.
# The values below are placeholders, not real secrets. The .env file is gitignored.

# --- Postgres (Nyas) -------------------------------------------------------
# Session pooling URI (IPv4-compatible; recommended for local dev / ORMs)
DATABASE_URL=postgresql://<user>.<project-id>:<password>@db-pool1.nyas.io:5432/<dbname>

# --- S3-compatible storage (Nyas) -----------------------------------------
S3_ENDPOINT=https://<project-id>.storage.nyas.io/v1/s3
S3_REGION=ap-south-1
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
S3_BUCKET=audio
